{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/pages/(.*)", "destination": "/public/pages/$1" },
    { "source": "/assets/(.*)", "destination": "/public/assets/$1" },
    { "source": "/", "destination": "/public/index.html" }
  ]
}
